# =============================================================================
# datahunter — variaveis de ambiente
# Copie este arquivo para .env e ajuste os valores.
# NUNCA commite o .env com senhas reais.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (usadas pelo servico postgres no compose)
# -----------------------------------------------------------------------------
POSTGRES_DB=datahunter
POSTGRES_USER=datahunter
POSTGRES_PASSWORD=datahunter        # troque em producao

# -----------------------------------------------------------------------------
# Celery / Worker
# Lidas por WorkerSettings via pydantic-settings (prefixo DATAHUNTER_)
# -----------------------------------------------------------------------------
DATAHUNTER_REDIS_URL=redis://redis:6379/0
DATAHUNTER_DATABASE_URL=postgresql+psycopg2://datahunter:datahunter@postgres:5432/datahunter
DATAHUNTER_SCRAPING_INTERVAL_SECONDS=3600   # intervalo do Beat (padrao: 1h)

# -----------------------------------------------------------------------------
# Aplicacao geral
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
